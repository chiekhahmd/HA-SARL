{
  "name": "@society-erp/api",
  "version": "0.1.0",
  "private": true,
  "description": "API Lambda — Hono router with all resource endpoints",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:@aws-sdk/*",
    "dev": "tsx watch src/dev-server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.600.0",
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@hono/node-server": "^2.0.8",
    "@hono/zod-validator": "^0.3.0",
    "drizzle-orm": "^0.33.0",
    "hono": "^4.5.0",
    "jose": "^5.6.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.140",
    "@types/node": "^26.1.0",
    "drizzle-kit": "^0.24.0",
    "esbuild": "^0.23.0",
    "tsx": "^4.16.0"
  }
}
